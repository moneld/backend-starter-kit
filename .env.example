# Application
NODE_ENV=development
PORT=3000
API_PREFIX=api
API_VERSION=1
APP_NAME=NestJS Fastify Starter
APP_URL=http://localhost:3000
CORS_ORIGIN=*
DEFAULT_LANGUAGE=fr
SUPPORTED_LANGUAGES=fr,en

# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/nest_fastify_starter?schema=public"

# JWT
JWT_ACCESS_SECRET=super_secret_access_key_change_in_production
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_SECRET=super_secret_refresh_key_change_in_production
JWT_REFRESH_EXPIRATION=7d

# Email
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=user@example.com
SMTP_PASSWORD=password
SMTP_FROM_EMAIL=noreply@example.com
SMTP_FROM_NAME=NestJS Fastify Starter

# Security
ARGON2_MEMORY_COST=4096
ARGON2_HASH_LENGTH=32
ARGON2_TIME_COST=3
ARGON2_PARALLELISM=1

# Rate limiting
RATE_LIMIT_TTL=60
RATE_LIMIT_LIMIT=100

# 2FA
TWO_FACTOR_AUTHENTICATION_APP_NAME=NestJS Fastify Starter

# Logging
LOG_LEVEL=info
LOG_TO_FILE=false
LOG_FILE_PATH=logs/app.log
